# Ignore the contents of the _site directory and other cache directories
_site/
.sass-cache/

# Ignore the directory for local files during development
local/

# Ignore the Gemfile that is generated
Gemfile.lock

# Ignore files created by npm
node_modules
package-lock.json

# Ignore the vendor file at root level and bundle for alternative installation
/vendor/
.bundle/

# Ignore folders related to IDEs
.vscode/

# Ignore files created by MacOS
.DS_Store

# Local source materials (original CV/headshot/Scholar export), not published
_source/

# Local tooling & editor/dev config (not part of the published site)
.devcontainer/

# Internal setup notes
SETUP.md

# Unused AcademicPages template utilities, demo data & docs-only images
markdown_generator/
scripts/
images/themes/
.github/CONTRIBUTING.md
.github/ISSUE_TEMPLATE/
.github/PULL_REQUEST_TEMPLATE.md

# Private documents (annual evaluations, etc.) - never publish
*Annual Evaluation*.pdf
